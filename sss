local MainTab = Window:CreateTab("Main", 4483362458) -- Title, Image

local Button = MainTab:CreateButton({
   Name = "Present ESP",
   Callback = function()
    local presentsFolder = workspace:WaitForChild("Presents")

local function addHighlight(obj)
	if not obj:IsA("Model") and not obj:IsA("BasePart") then
		return
	end

	-- Prevent duplicate highlights
	if obj:FindFirstChild("PresentHighlight") then
		return
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = "PresentHighlight"
	highlight.FillColor = Color3.fromRGB(255, 255, 0) -- Yellow
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	highlight.FillTransparency = 0.4
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = obj
end

-- Highlight existing presents
for _, obj in ipairs(presentsFolder:GetChildren()) do
	if obj.Name == "Present" then
		addHighlight(obj)
	end
end

-- Highlight newly spawned presents
presentsFolder.ChildAdded:Connect(function(obj)
	if obj.Name == "Present" then
		task.wait() -- allow object to finish loading
		addHighlight(obj)
	end
end)
   end,
})

